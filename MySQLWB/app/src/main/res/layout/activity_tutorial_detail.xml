<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:titleTextColor="@color/text_on_primary"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/primary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/tv_tutorial_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📖"
                        android:textSize="36sp"/>

                    <TextView
                        android:id="@+id/tv_tutorial_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tutorial Title"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/tv_tutorial_meta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Beginner · DDL Commands"
                        android:textColor="#AACCEE"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Content -->
            <TextView
                android:id="@+id/tv_tutorial_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="16dp"/>

            <!-- Try It Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="#1E1E1E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💻 Example Query"
                        android:textColor="#569CD6"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_example_sql"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#D4D4D4"
                        android:textSize="13sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.5"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Try in Editor -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_try_in_editor"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="▶ Try in Query Editor"
                android:textColor="#FFFFFF"
                app:backgroundTint="@color/success_color"
                app:cornerRadius="10dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
