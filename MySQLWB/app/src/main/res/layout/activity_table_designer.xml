<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:titleTextColor="@color/text_on_primary"
        app:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"/>

    <!-- Table Name Row -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Table Name:"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:minWidth="90dp"/>

            <EditText
                android:id="@+id/et_table_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="e.g. students"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:imeOptions="actionNext"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Column Headers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2.5"
            android:text="Column Name" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2"
            android:text="Type" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8"
            android:text="PK" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8"
            android:text="NN" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8"
            android:text="AI" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" android:gravity="center"/>
        <View android:layout_width="32dp" android:layout_height="1dp"/>
    </LinearLayout>

    <!-- Columns List -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/columns_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp"/>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:padding="14dp">

        <!-- Add Column button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_column"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="+ Add Column"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/primary"
            android:textColor="@color/primary"
            app:cornerRadius="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- SQL Preview -->
        <TextView
            android:id="@+id/tv_sql_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-- SQL Preview will appear here"
            android:textColor="#888888"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="#F5F5F5"
            android:padding="10dp"
            android:maxLines="5"
            android:ellipsize="end"
            android:layout_marginBottom="8dp"/>

        <!-- Create Table button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_table"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="⚡ Create Table"
            android:textColor="#FFFFFF"
            app:backgroundTint="@color/success_color"
            app:cornerRadius="10dp"/>

    </LinearLayout>

</LinearLayout>
