<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="40dp">

    <!-- Logo Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <!-- App Icon -->
        <ImageView
            android:id="@+id/splash_logo"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:src="@drawable/ic_database_logo"
            android:contentDescription="MySQL WB Logo"/>

        <!-- Glowing ring effect -->
        <View
            android:layout_width="130dp"
            android:layout_height="2dp"
            android:layout_marginTop="16dp"
            android:background="#442196F3"/>

    </LinearLayout>

    <!-- App Name -->
    <TextView
        android:id="@+id/splash_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="MySQL WB"
        android:textColor="#FFFFFF"
        android:textSize="38sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05"/>

    <!-- Tagline -->
    <TextView
        android:id="@+id/splash_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Mobile SQL Workspace"
        android:textColor="#AAC8E0"
        android:textSize="15sp"
        android:letterSpacing="0.1"/>

    <!-- Separator line -->
    <View
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:layout_marginTop="20dp"
        android:background="#E8831A"/>

    <!-- Feature tags -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SQL"
            android:textColor="#9AB8D0"
            android:textSize="12sp"
            android:letterSpacing="0.15"/>

        <View
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:layout_marginHorizontal="10dp"
            android:background="#E8831A"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DBMS"
            android:textColor="#9AB8D0"
            android:textSize="12sp"
            android:letterSpacing="0.15"/>

        <View
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:layout_marginHorizontal="10dp"
            android:background="#E8831A"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RDBMS"
            android:textColor="#9AB8D0"
            android:textSize="12sp"
            android:letterSpacing="0.15"/>

    </LinearLayout>

    <!-- Bottom info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/splash_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.5.1"
            android:textColor="#557A99"
            android:textSize="12sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="🔒 Offline Mode — No server required"
            android:textColor="#557A99"
            android:textSize="11sp"/>

    </LinearLayout>

</LinearLayout>
