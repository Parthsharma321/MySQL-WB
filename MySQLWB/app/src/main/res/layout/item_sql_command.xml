<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Command Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tv_command"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SELECT"
                android:textColor="@color/syntax_keyword"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/tv_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DQL"
                android:textSize="10sp"
                android:textColor="@color/primary"
                android:background="@drawable/bg_tag_keyword"
                android:padding="3dp"
                android:paddingHorizontal="8dp"/>

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/tv_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Retrieves data from one or more tables"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <!-- Syntax Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/editor_bg"
            android:padding="10dp">

            <TextView
                android:id="@+id/tv_syntax"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SELECT col1, col2 FROM table_name;"
                android:textColor="#CE9178"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
